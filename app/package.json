{
  "name": "@omniwork/app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "generate:xterm-assets": "node ./scripts/generateXtermWebViewAssets.mjs",
    "start": "pnpm run generate:xterm-assets && react-native start",
    "android": "pnpm run generate:xterm-assets && react-native run-android",
    "ios": "pnpm run generate:xterm-assets && react-native run-ios",
    "build:android:apk": "pnpm run generate:xterm-assets && react-native build-android --mode release --tasks assembleRelease",
    "build:android:aab": "pnpm run generate:xterm-assets && react-native build-android --mode release --tasks bundleRelease",
    "pods:ios": "cd ios && mkdir -p ../.cocoapods-home && CP_HOME_DIR=\"$PWD/../.cocoapods-home\" pod install",
    "pods:ios:ensure": "node ./scripts/ensureIosPods.mjs",
    "build:ios:dev": "pnpm run generate:xterm-assets && pnpm run pods:ios:ensure && react-native build-ios --mode Release --extra-params \"CODE_SIGNING_ALLOWED=NO\"",
    "build:ios": "pnpm run generate:xterm-assets && pnpm run pods:ios:ensure && node ./scripts/buildIosRelease.mjs",
    "web:dev": "pnpm run generate:xterm-assets && webpack serve --config webpack.config.js --mode development",
    "web:build": "pnpm run generate:xterm-assets && webpack --config webpack.config.js --mode production",
    "bundle:ios": "pnpm run generate:xterm-assets && react-native bundle --platform ios --dev false --entry-file index.js --bundle-output /tmp/omniwork-ios.bundle --assets-dest /tmp/omniwork-ios-assets",
    "bundle:android": "pnpm run generate:xterm-assets && react-native bundle --platform android --dev false --entry-file index.js --bundle-output /tmp/omniwork-android.bundle --assets-dest /tmp/omniwork-android-assets",
    "verify:web": "pnpm run web:build",
    "verify:bundle:ios": "pnpm run bundle:ios",
    "verify:bundle:android": "pnpm run bundle:android",
    "verify:targets": "pnpm run typecheck && pnpm run bundle:ios && pnpm run bundle:android && pnpm run web:build",
    "typecheck": "pnpm run generate:xterm-assets && tsc -p tsconfig.json",
    "lint": "pnpm run generate:xterm-assets && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run generate:xterm-assets && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@omniwork/e2e-noise": "workspace:*",
    "@omniwork/protocol-ts": "workspace:*",
    "@omniwork/relay-client": "workspace:*",
    "@omniwork/terminal-core": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/assets-registry": "^0.83.6",
    "@react-native/normalize-colors": "^0.83.6",
    "@react-native/virtualized-lists": "^0.83.6",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "abort-controller": "^3.0.0",
    "anser": "^2.3.5",
    "ansi-regex": "^6.2.2",
    "ansi-styles": "^6.2.3",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "event-target-shim": "^6.0.2",
    "i18next": "^26.3.0",
    "ieee754": "^1.2.1",
    "invariant": "^2.2.4",
    "memoize-one": "^6.0.0",
    "metro-runtime": "^0.84.4",
    "nullthrows": "^1.1.1",
    "pretty-format": "^30.4.1",
    "promise": "^8.3.0",
    "punycode": "^2.3.1",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-is-18": "npm:react-is@18",
    "react-is-19": "npm:react-is@19",
    "react-native": "0.83.6",
    "react-native-camera-kit": "^18.0.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-keychain": "^10.0.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-webrtc": "^124.0.4",
    "react-native-webview": "^13.16.1",
    "react-refresh": "^0.18.0",
    "regenerator-runtime": "^0.14.1",
    "scheduler": "^0.27.0",
    "stacktrace-parser": "^0.1.11",
    "webidl-conversions": "^8.0.1",
    "whatwg-fetch": "^3.6.20",
    "whatwg-url-without-unicode": "8.0.0-3"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native-community/cli": "^20.1.2",
    "@react-native-community/cli-platform-android": "^20.1.2",
    "@react-native-community/cli-platform-ios": "^20.1.2",
    "@react-native/babel-preset": "0.83.6",
    "@react-native/codegen": "0.83.6",
    "@react-native/gradle-plugin": "0.83.6",
    "@react-native/metro-config": "0.83.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.4",
    "hermes-compiler": "0.14.1",
    "html-webpack-plugin": "^5.6.4",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.0",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
