{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "OMNIWORK_APP_ENV": "preview"
      }
    },
    "apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "OMNIWORK_APP_ENV": "apk"
      }
    },
    "ipa": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "OMNIWORK_APP_ENV": "ipa"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "OMNIWORK_APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
