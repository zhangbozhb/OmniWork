server {
    listen 443 ssl http2;
    server_name omniwork.example.com;

    # Replace these with the certificate paths managed by your deployment.
    ssl_certificate /etc/letsencrypt/live/omniwork.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/omniwork.example.com/privkey.pem;

    # Project landing page. Optional until a site build is added.
    location / {
        root /var/www/omniwork/site;
        try_files $uri $uri/ /index.html;
    }

    # Web client. Built by pnpm deploy:web:build into dist/deploy/app.
    location /app/ {
        alias /var/www/omniwork/app/;
        try_files $uri $uri/ /app/index.html;
    }

    # Production admin web. Built by pnpm deploy:web:build into dist/deploy/admin.
    location /admin/ {
        alias /var/www/omniwork/admin/;
        try_files $uri $uri/ /admin/index.html;
    }

    # Admin API is always served by relay server.
    location /admin/api/ {
        proxy_pass http://127.0.0.1:8787/admin/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
          # Overwrite any client-supplied X-Forwarded-For. Relay trusts this
          # header only from configured proxy IPs, so it must contain Nginx's
          # observed peer IP rather than an appended client-controlled chain.
          proxy_set_header X-Forwarded-For $remote_addr;
    }

    # Relay WebSocket endpoints for Agent and App/Web client.
    location /relay/ws/ {
        proxy_pass http://127.0.0.1:8787/relay/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
          # Overwrite any client-supplied X-Forwarded-For for GeoIP, IP bans,
          # and auth rate limiting.
          proxy_set_header X-Forwarded-For $remote_addr;
    }

    location /healthz {
        proxy_pass http://127.0.0.1:8787/healthz;
    }

    location /readyz {
        proxy_pass http://127.0.0.1:8787/readyz;
    }

    # Keep operational endpoints off the public internet.
    location /metrics {
        allow 127.0.0.1;
        deny all;
        proxy_pass http://127.0.0.1:8787/metrics;
    }

    location /debug/ {
        deny all;
    }
}
