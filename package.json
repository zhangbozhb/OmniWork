{
  "name": "omniwork",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:app": "pnpm --filter @omniwork/app start",
    "dev:web": "pnpm --filter @omniwork/app web:dev",
    "dev:mac": "pnpm --filter @omniwork/mac-agent dev",
    "dev:relay": "pnpm --filter @omniwork/relay-server dev",
    "app:android": "pnpm --filter @omniwork/app android",
    "app:ios": "pnpm --filter @omniwork/app ios",
    "app:setup:ios": "pnpm --filter @omniwork/app setup:ios",
    "app:build:web": "pnpm --filter @omniwork/app web:build",
    "app:build:android:apk": "pnpm --filter @omniwork/app build:android:apk",
    "app:build:android:aab": "pnpm --filter @omniwork/app build:android:aab",
    "app:build:ios": "pnpm --filter @omniwork/app build:ios",
    "app:build:ios:dev": "pnpm --filter @omniwork/app build:ios:dev",
    "relay:start": "pnpm --filter @omniwork/relay-server start",
    "verify:app-auth": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify/app-key-proof.test.mjs",
    "verify:app:targets": "pnpm --filter @omniwork/app verify:targets",
    "verify:app:web": "pnpm --filter @omniwork/app verify:web",
    "verify:app:bundle:ios": "pnpm --filter @omniwork/app verify:bundle:ios",
    "verify:app:bundle:android": "pnpm --filter @omniwork/app verify:bundle:android",
    "verify:package-boundaries": "node scripts/verify/package-boundaries.mjs",
    "verify:relay": "node --experimental-strip-types relay/server/src/main.ts --check",
    "verify:mac-key": "node --experimental-strip-types mac/agent/tests/auth-key.test.ts",
    "verify:upgrade:simulator": "node --experimental-strip-types scripts/verify/mobile-upgrade-simulator.mjs",
    "verify:security": "pnpm --filter @omniwork/e2e-noise test"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@react-native-community/cli": "latest"
  }
}
