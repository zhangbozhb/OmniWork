{
  "name": "omniwork",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:app": "pnpm --filter @omniwork/app start",
    "dev:mac": "pnpm --filter @omniwork/mac-agent dev",
    "dev:relay": "pnpm --filter @omniwork/relay-server dev",
    "app:android": "pnpm --filter @omniwork/app android",
    "app:ios": "pnpm --filter @omniwork/app ios",
    "app:build:android": "pnpm --filter @omniwork/app build:android",
    "app:build:ios": "pnpm --filter @omniwork/app build:ios",
    "relay:start": "pnpm --filter @omniwork/relay-server start",
    "verify:app-auth": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify/app-key-proof.test.mjs",
    "verify:relay": "node --experimental-strip-types relay/server/src/main.ts --check",
    "verify:mac-key": "node --experimental-strip-types mac/agent/tests/auth-key.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
